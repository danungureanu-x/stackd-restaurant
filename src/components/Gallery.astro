---
const panels = [
  {
    img: 'https://images.unsplash.com/photo-1586816001966-79b736744398?w=1800&q=80&auto=format&fit=crop',
    alt: 'Smash burger close-up',
    text: 'No freezers.\nNo shortcuts.',
  },
  {
    img: 'https://images.unsplash.com/photo-1630384060421-cb20d0e0649d?w=1800&q=80&auto=format&fit=crop',
    alt: 'Crispy smash fries',
    text: 'Fresh beef.\nEvery order.',
  },
  {
    img: 'https://images.unsplash.com/photo-1565299507177-b0ac66763828?w=1800&q=80&auto=format&fit=crop',
    alt: 'STACKD restaurant interior',
    text: 'Come as you are.\nLeave obsessed.',
  },
];
---
<section class="gallery" id="gallery" aria-label="Gallery">
  {panels.map((panel, i) => (
    <div class="gallery__panel">
      <img src={panel.img} alt={panel.alt} loading="lazy" />
      <div class="gallery__overlay"></div>
      <p class="gallery__text reveal">{panel.text}</p>
    </div>
  ))}
</section>

<style>
  .gallery { display: flex; flex-direction: column; }

  .gallery__panel {
    position: relative;
    height: 85vh;
    overflow: hidden;
  }
  .gallery__panel img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    transition: transform 0.6s ease;
  }
  .gallery__panel:hover img { transform: scale(1.03); }

  .gallery__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      transparent 30%,
      rgba(13, 12, 10, 0.75) 100%
    );
  }

  .gallery__text {
    position: absolute;
    bottom: 3.5rem;
    left: 3.5rem;
    font-family: var(--font-mono);
    font-size: clamp(1.8rem, 4vw, 3.5rem);
    font-weight: 700;
    text-transform: uppercase;
    line-height: 1.15;
    color: var(--text);
    white-space: pre-line;
    letter-spacing: -0.02em;
    max-width: 700px;
  }

  @media (max-width: 768px) {
    .gallery__panel { height: 60vh; }
    .gallery__text { left: 1.5rem; bottom: 2rem; font-size: 1.6rem; }
  }
</style>
